{
  "name": "@hyperse/hps-website",
  "version": "0.0.2",
  "description": "Hyperse documentation website",
  "private": true,
  "homepage": "https://github.com/hyperse-io/hps#readme",
  "bugs": {
    "url": "https://github.com/hyperse-io/hps/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:hyperse-io/hps.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build && yarn postbuild",
    "postbuild": "next-sitemap && pagefind --site .next/server/app --output-path public/_pagefind",
    "build:ghpage": "cross-env NEXT_BUILD_ENV_OUTPUT='export' next build && yarn postbuild:ghpage",
    "postbuild:ghpage": "next-sitemap && pagefind --site .next/server/app --output-path out/_pagefind",
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "fix-all-files": "eslint . --fix",
    "g:lint-staged-files": "lint-staged --allow-empty",
    "lint": "eslint .",
    "start": "next start -p 3000 -H 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc --project ./tsconfig.json --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@dimjs/utils": "^2.1.7",
    "@heroui/react": "^3.0.1",
    "@iconify/react": "^6.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@hyperse/eslint-config-hyperse": "^1.7.1",
    "@hyperse/next-config": "^1.0.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "next-sitemap": "^4.2.3",
    "pagefind": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
