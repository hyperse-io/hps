    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "webpack": "^5.106.2"
  },
  "peerDependencies": {
    "@hyperse/wizard": ">=1.0.6",
